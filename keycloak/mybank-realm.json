{
  "realm": "mybank",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Regular user role"
      },
      {
        "name": "SERVICE_ACCESS",
        "description": "Service-to-service access role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "mybank-frontend",
      "secret": "frontend-secret",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:8082/*",
        "http://frontend.mybank.local/*"
      ],
      "webOrigins": [
        "http://localhost:8082",
        "http://frontend.mybank.local"
      ]
    },
    {
      "clientId": "cash-service",
      "secret": "cash-secret",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret"
    },
    {
      "clientId": "transfer-service",
      "secret": "transfer-secret",
      "enabled": true,
