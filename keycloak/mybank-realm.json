      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret"
    },
    {
      "clientId": "accounts-service",
      "secret": "accounts-service-secret",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret"
    }
  ],
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "email": "user1@mybank.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    },
    {
      "username": "user2",
      "enabled": true,
